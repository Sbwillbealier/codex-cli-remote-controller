{
  "name": "@codex-remote-controller/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit --pretty false",
    "start": "node dist/main.js",
    "pair": "tsx src/cli.ts pair",
    "devices:list": "tsx src/cli.ts devices:list",
    "devices:revoke": "tsx src/cli.ts devices:revoke"
  },
  "dependencies": {
    "@fastify/multipart": "^9.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@xterm/headless": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.6.2",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
