# Copy this file to apps/server/.env and adjust values for your machine.

# Server
PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info

# Public URL used in pairing QR codes.
# Use a domain or LAN address reachable from your phone.
PUBLIC_CONTROLLER_URL=http://your-domain-or-host:8787

# Codex adapter
# mock = UI/demo output, pty = real Codex CLI through node-pty.
CODEX_ADAPTER=pty
CODEX_CLI_COMMAND=codex
CODEX_CLI_ARGS=--no-alt-screen
# Leave empty to use the current project directory, or set an absolute path.
CODEX_WORKSPACE=

# Token telemetry
# Uses a separate short-lived Codex process, so it does not type /status into the active session.
CODEX_TOKEN_AUTO_REFRESH=true
CODEX_TOKEN_REFRESH_MS=300000
CODEX_TOKEN_PROBE_TIMEOUT_MS=20000
CODEX_TOKEN_PROBE_FIRST_STATUS_DELAY_MS=1800
CODEX_TOKEN_PROBE_RETRY_MS=3500

# Session and data
CODEX_SESSION_KEEPALIVE_MS=600000
CONTROLLER_DATA_DIR=data
CONTROLLER_UPLOAD_DIR=data/uploads

# Optional admin token for non-loopback admin API access.
CODEX_ADMIN_TOKEN=
